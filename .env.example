# EmailJS credentials for the contact form.
# Create a free account at https://www.emailjs.com/ and copy the IDs here.
# Copy this file to `.env` (or `.env.local`) and fill in real values.
# If left unset, the contact form gracefully falls back to a mailto: link.

VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=
